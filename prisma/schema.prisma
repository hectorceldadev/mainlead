// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  COLD 
  TEMPERED
  HOT 
  CLOSED
}

enum LeadSource {
  MANUAL
  GOOGLE_PLACES
  LINKEDIN
}

model User {
  id String @id @default(uuid())

  userId String
  username String

  credits Int @default(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stripeCustomerId String? @unique

  leads Lead[]
  companies Company[]
  contacts Contact[]

  historyCompanies HistoryCompany[]
  historyContacts HistoryContact[]

  subscription Subscription?

  @@unique([userId])
}

model Company {
  id String @id @default(uuid())

  placeId String? @unique

  name String
  location String?

  phone String?
  email String?

  websiteUrl String?

  historyCompanies HistoryCompany[]

  userId String
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  contacts Contact[]
  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Contact {
  id String @id @default(uuid())

  name String

  role String?

  email String?
  phone String?

  companyId String?
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  historyContacts HistoryContact[]

  userId String
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  leads Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Lead {
  id String @id @default(uuid())

  status LeadStatus @default(COLD)

  title String?
  description String?

  source LeadSource @default(MANUAL)

  companyId String?
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  contactId String?
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  userId String
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model HistoryCompany {
  id String @id @default(uuid())

  placeId String?
  linkedInId String?

  name String
  location String?
  phone String?
  email String?
  websiteUrl String?
  rating Float?
  userRatingCount Int?

  source LeadSource

  savedCompanyId String?
  savedCompany Company? @relation(fields: [savedCompanyId], references: [id], onDelete: SetNull)

  userId String
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  historyContacts HistoryContact[]

  createdAt DateTime @default(now())

  @@unique([placeId])
  @@unique([linkedInId])
  @@index([userId])
  @@index([source])
  @@index([userId, savedCompanyId])
}

model HistoryContact {
  id String  @id @default(uuid())

  linkedInUrl String?  

  name String
  role String?
  email String?
  phone String?

  source LeadSource

  historyCompanyId String?
  historyCompany HistoryCompany? @relation(fields: [historyCompanyId], references: [id], onDelete: SetNull)

  savedContactId String?
  savedContact Contact? @relation(fields: [savedContactId], references: [id], onDelete: SetNull)

  userId String
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([source])
}

model Subscription {
  id String @id @default(uuid())

  planId String
  status String
  stripeSubscriptionId String @unique
  stripePriceId String 
  currentPeriodStart DateTime
  currentPeriodEnd DateTime
  creditsGranted Int @default(0)
  cancelAtPeriodEnd Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId String @unique
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}